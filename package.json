{
  "name": "@invariance/sdk",
  "version": "0.1.2",
  "description": "Official TypeScript SDK for the Invariance AI platform.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./record": {
      "types": "./dist/record/index.d.ts",
      "import": "./dist/record/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "parity": "tsx scripts/parity-check.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "invariance",
    "sdk",
    "ai",
    "monitoring",
    "observability",
    "mcp"
  ],
  "author": "Invariance AI <hello@invariance.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/invariance-ai/invariance-typescript.git"
  },
  "homepage": "https://github.com/invariance-ai/invariance-typescript#readme",
  "bugs": {
    "url": "https://github.com/invariance-ai/invariance-typescript/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  }
}
